#!/usr/bin/env bash
# lanes — Claude Code multi-worktree dispatcher.
set -euo pipefail

SKILL="${LANES_SKILL_DIR:-$HOME/.claude/skills/lanes/scripts}"

cmd="${1:-help}"
shift || true

case "$cmd" in
  start)
    lane="${1:-}"
    [ -z "$lane" ] && { echo "usage: lanes start <lane>"; exit 1; }
    shift || true
    exec claude --worktree "$lane" "$@"
    ;;
  monitor)
    "$SKILL/status.sh" "${1:-main}"
    echo
    "$SKILL/overlap.sh" "${1:-main}"
    ;;
  log)
    exec "$SKILL/log-lanes.sh" "${1:-main}"
    ;;
  lanes)
    exec "$SKILL/lanes.sh" "${1:-main}"
    ;;
  merge)
    if [ $# -eq 0 ]; then
      CURRENT="$(git branch --show-current)"
      echo "Available lanes to merge into $CURRENT:"
      echo
      printf "  %-30s %8s %8s\n" "LANE" "AHEAD" "BEHIND"
      git worktree list --porcelain | awk '
        /^worktree / { p=$2 }
        /^branch /   { b=$2; sub("refs/heads/", "", b)
                       nb=p; sub(".*/","",nb)
                       print nb "\t" b }
      ' | while IFS=$'\t' read -r short branch; do
        [ "$branch" = "$CURRENT" ] && continue
        ahead="$(git rev-list --count "$CURRENT..$branch" 2>/dev/null || echo 0)"
        behind="$(git rev-list --count "$branch..$CURRENT" 2>/dev/null || echo 0)"
        printf "  %-30s %8s %8s\n" "$short" "$ahead" "$behind"
      done
      echo
      echo "Run: lanes merge <lane>"
      exit 0
    fi
    exec "$SKILL/merge-lane.sh" "$@"
    ;;
  help|-h|--help|"")
    cat <<'EOF'
lanes — Claude Code multi-worktree dispatcher

WHERE ARE YOU?

  Outside any lane (in main worktree)
    lanes start <lane>      Launch Claude Code in a worktree (creates if needed)
    lanes monitor           Status + overlap across all lanes
    lanes log               Commit history for every lane
    lanes list             List worktrees and lane branches
    lanes merge <lane>      Merge a finished lane into the current branch

  Inside a Claude Code lane (slash commands)
    While working
      /handoff           Update .claude-lane-status.md (handoff notes)
      /checkpoint <msg>  Commit current changes with your message
      /wrap              Auto-write a 1-2 sentence message and commit

    Looking around (read-only)
      /monitor           Status + overlap across all lanes
      /lane <name>       Inspect one lane in detail
      /log-lanes         Commit history for every lane

    Wrapping up
      /integrate-next    Recommend the safest lane to merge next
      /merge-lane <name> Actually merge a lane into the current branch

LANE NAMES

  Refer to lanes by their short name (the worktree dir): "esc", "feat-auth".
  The git branch is "worktree-<name>" (Claude Code's convention) — tooling
  resolves either form, so you almost never type the branch name.

WHEN TO USE WHAT

  Starting fresh         lanes start feat-foo
  Mid-work save          /checkpoint "added validation"   (you write the msg)
  Mid-work, lazy         /wrap                            (Claude writes the msg)
  "What's everyone up to" /monitor   or   lanes monitor
  "Am I done?"           /handoff   then   /integrate-next
  Bring a lane home      /merge-lane feat-foo   or   lanes merge feat-foo

Nothing here pushes to GitHub or deletes worktrees.
EOF
    ;;
  *)
    echo "unknown subcommand: $cmd"
    echo "run: lanes help"
    exit 1
    ;;
esac
