#!/usr/bin/env bash
# lanes — Claude Code multi-worktree dispatcher.
set -euo pipefail

SKILL="${LANES_SKILL_DIR:-$HOME/.claude/skills/lanes/scripts}"

cmd="${1:-help}"
shift || true

case "$cmd" in
  start)
    lane="${1:-}"
    [ -z "$lane" ] && { echo "usage: lanes start <lane>"; exit 1; }
    shift || true
    exec claude --worktree "$lane" "$@"
    ;;
  monitor)
    "$SKILL/status.sh" "${1:-main}"
    echo
    "$SKILL/overlap.sh" "${1:-main}"
    ;;
  log)
    exec "$SKILL/log-lanes.sh" "${1:-main}"
    ;;
  list)
    exec "$SKILL/lanes.sh" "${1:-main}"
    ;;
  inspect)
    lane="${1:-}"
    [ -z "$lane" ] && { echo "usage: lanes inspect <lane>"; exit 1; }
    exec "$SKILL/status.sh" main "$lane"
    ;;
  next)
    next_lane="$("$SKILL/integrate-next.sh" name)"
    if [ -z "$next_lane" ]; then
      echo "No lanes have unintegrated commits. Nothing to merge."
      exit 0
    fi
    "$SKILL/integrate-next.sh" pick
    echo
    exec "$SKILL/merge-lane.sh" "$next_lane"
    ;;
  merge)
    if [ $# -eq 0 ]; then
      exec "$SKILL/integrate-next.sh" list
    fi
    if [ "${1:-}" = "next" ]; then
      next_lane="$("$SKILL/integrate-next.sh" name)"
      if [ -z "$next_lane" ]; then
        echo "No lanes have unintegrated commits. Nothing to merge."
        exit 0
      fi
      "$SKILL/integrate-next.sh" pick
      echo
      exec "$SKILL/merge-lane.sh" "$next_lane"
    fi
    exec "$SKILL/merge-lane.sh" "$@"
    ;;
  union)
    if [ $# -eq 0 ]; then
      cat <<'EOF'
usage: lanes union <path> [<path>...]

Marks paths with git's 'union' merge driver in this repo's
.git/info/attributes (local to your clone, not committed). Append-only
logs (UX_LOG.md, CHANGELOG.md, etc.) auto-concatenate on merge instead
of producing conflicts.

Example:
  lanes union UX_LOG.md
  lanes union UX_LOG.md CHANGELOG.md docs/RELEASES.md

To share with the team, commit `<path> merge=union` to .gitattributes
instead of running this command.
EOF
      exit 1
    fi
    git_dir="$(git rev-parse --git-common-dir 2>/dev/null)" || {
      echo "Not in a git repository."
      exit 1
    }
    attrs="$git_dir/info/attributes"
    mkdir -p "$git_dir/info"
    touch "$attrs"
    for path in "$@"; do
      line="$path merge=union"
      if grep -Fxq "$line" "$attrs"; then
        echo "already set: $line"
      else
        printf '%s\n' "$line" >> "$attrs"
        echo "added: $line"
      fi
    done
    echo
    echo "Wrote to $attrs (local to this clone, not committed)."
    ;;
  help|-h|--help|"")
    cat <<'EOF'
lanes — Claude Code multi-worktree dispatcher

CLI (run from your main worktree shell)

  Start
    lanes start <lane>     Launch Claude Code in a worktree (creates if needed)

  Look around
    lanes monitor          Status + overlap across all lanes
    lanes log              Commit history for every lane
    lanes list             List worktrees and lane branches
    lanes inspect <lane>   Detail view of a single lane

  Integrate
    lanes merge            Show lanes with commits to integrate (safest first)
    lanes merge <lane>     Integrate that lane into the current branch
    lanes next             Integrate the safest lane automatically
    lanes merge next       Same as 'lanes next'

  Conflict-free append-only files
    lanes union <path>...  Mark paths with git's 'union' merge driver in this
                           repo's .git/info/attributes (local, not committed).
                           Useful for UX_LOG.md, CHANGELOG.md, etc.

Slash commands (run inside a Claude Code lane)

  /checkpoint <msg>        Commit current changes with your message
  /wrap                    Auto-write a 1-2 sentence message and commit
  /handoff                 Update .claude-lane-status.md handoff notes

LANE NAMES

  Refer to lanes by their short name (the worktree dir): "esc", "feat-auth".
  The git branch is "worktree-<name>" (Claude Code's convention) — tooling
  resolves either form, so you almost never type the branch name.

INTEGRATION MODE

  lanes merge picks the mode automatically based on how many *unintegrated*
  commits the lane has (patch-id aware, so re-integrating a lane after more
  work counts only the new commits):

    1-2 new commits  -> cherry-pick (linear history, no merge commit)
    3+  new commits  -> git merge --ff (merge commit only if target moved)

Nothing here pushes to GitHub or deletes worktrees.
EOF
    ;;
  *)
    echo "unknown subcommand: $cmd"
    echo "run: lanes help"
    exit 1
    ;;
esac
